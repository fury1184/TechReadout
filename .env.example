# TechReadOut environment configuration
# Copy this file to .env and fill in the values you need:
#   cp .env.example .env
# docker compose reads .env automatically. Only SECRET_KEY is required to boot;
# every integration below is optional and the app runs without it.

# ── Required ──────────────────────────────────────────────────────────────────
# Flask secret key. Set this to a long random string in production.
SECRET_KEY=change-this-in-production

# ── Database (optional) ───────────────────────────────────────────────────────
# Defaults to the bundled MariaDB "db" service in docker-compose.yml.
# Override only if pointing at an external database.
# DATABASE_URL=mysql+pymysql://techreadout:techreadout@db:3306/techreadout

# ── Scrape.Do (optional) ──────────────────────────────────────────────────────
# Paid web-scraping proxy used as the last-resort spec lookup fallback.
# Get a token at https://scrape.do (free tier available). Without it, lookups
# still work from the seed database — they just can't fetch specs for items
# outside the seed library.
SCRAPEDO_TOKEN=

# ── eBay Browse API (optional) ────────────────────────────────────────────────
# Used-market price estimates. Create a Production keyset at
# https://developer.ebay.com (My Account -> Application Keysets).
# App ID = Client ID, App Secret = Cert ID. Then enable eBay pricing in
# Lookup Settings.
EBAY_APP_ID=
EBAY_APP_SECRET=

# ── Open WebUI (optional) ─────────────────────────────────────────────────────
# Bearer token for a self-hosted Open WebUI instance used as an automatic
# LLM-based lookup step. Results always route to the Pending Review queue and
# are never auto-accepted. Configure the instance URL and model in Lookup Settings.
OPENWEBUI_API_TOKEN=

# ── Startup behavior (optional) ───────────────────────────────────────────────
# Set to false to skip the seed-import step on container startup.
# SEED_ON_STARTUP=true

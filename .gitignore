# Backups and exports
# -------------------------
backups/
backup/
exports/
export/
dumps/
*.dump
*.sql.gz
*.backup
*.bak
*.tar.gz

# Keep versioned SQL schema and migrations
!migrations/
!migrations/**
!migrations/*.sql

# -------------------------
# User inventory/import files
# -------------------------
uploads/
imports/
temp/
tmp/
*.csv
*.xlsx
*.xls

# Keep public seed specification files
!app/seeds/
!app/seeds/**
!app/seeds/*.json
!app/seeds/*.py

# -------------------------
# Logs
# -------------------------
logs/
*.log

# -------------------------
# Docker runtime files
# -------------------------
docker-data/
volumes/
*.pid

# Do not ignore tracked Docker configuration
!docker-compose.yml
!docker-compose.yaml
!Dockerfile
!Dockerfile.*

# -------------------------
# Editors and IDEs
# -------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# -------------------------
